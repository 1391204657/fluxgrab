# Copy to .env on the server (never commit real secrets)
# Lemon Squeezy — refund → disable license keys (required for Pro)
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_WEBHOOK_SECRET=

# Optional Stripe webhook (only if you sell via Stripe Payment Link)
STRIPE_WEBHOOK_SECRET=

# Optional — auto-email license keys after purchase (e.g. Gmail App Password, SendGrid SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM=FluxGrab <support@fluxgrab.com>
